---
import Section from "./Section.astro";
---

<Section id="contact" eyebrow="Say hello" title="Contact">
  <div class="contact-wrap reveal">
    <div class="details">
      <p>
        <a href="mailto:hello@hairysquid.com">hello@hairysquid.com</a>
      </p>
      <p>
        <a href="tel:+447480070409">+44 (0)7480 070409</a>
      </p>
      <p class="hint">...or fill out the form and we'll get back to you shortly.</p>
    </div>

    <form id="contact-form" class="form">
      <label>
        Name
        <input type="text" name="name" required />
      </label>
      <label>
        Topic
        <input type="text" name="topic" />
      </label>
      <label>
        Message
        <textarea name="message" rows="5" required></textarea>
      </label>
      <button type="submit">Submit</button>
      <p class="status" role="status"></p>
    </form>
  </div>
</Section>

<style>
  .contact-wrap {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 3rem;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 24px;
    padding: 2.5rem;
    backdrop-filter: blur(6px);
  }

  .details p {
    margin: 0 0 1rem;
    font-size: 1.15rem;
  }

  .details a {
    color: var(--lime);
    font-weight: 700;
    text-decoration: none;
  }

  .details a:hover {
    color: var(--pink-light);
  }

  .hint {
    color: rgba(255, 248, 236, 0.65);
    font-size: 0.95rem !important;
  }

  .form {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  label {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: rgba(255, 248, 236, 0.7);
  }

  input,
  textarea {
    font-family: inherit;
    font-size: 1rem;
    padding: 0.8rem 1rem;
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    background: rgba(0, 0, 0, 0.35);
    color: var(--cream);
    resize: vertical;
  }

  input:focus,
  textarea:focus {
    outline: none;
    border-color: var(--pink);
    box-shadow: 0 0 0 3px rgba(236, 30, 147, 0.25);
  }

  button {
    align-self: flex-start;
    padding: 0.9rem 2rem;
    border: none;
    border-radius: 999px;
    font-weight: 800;
    font-size: 1rem;
    cursor: pointer;
    color: var(--ink);
    background: linear-gradient(90deg, var(--lime), var(--pink-light));
    background-size: 160% auto;
    transition: background-position 0.4s ease, transform 0.25s ease;
  }

  button:hover {
    background-position: 100% center;
    transform: translateY(-2px);
  }

  button:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .status {
    margin: 0;
    font-weight: 700;
  }

  @media (max-width: 800px) {
    .contact-wrap {
      grid-template-columns: 1fr;
      padding: 1.75rem;
    }
  }
</style>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const statusEl = form.querySelector(".status") as HTMLParagraphElement;
  const button = form.querySelector("button") as HTMLButtonElement;

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    button.disabled = true;
    statusEl.textContent = "Sending...";
    statusEl.style.color = "var(--lime)";

    try {
      const res = await fetch("https://formspree.io/f/xqkwlonj", {
        method: "POST",
        headers: { Accept: "application/json" },
        body: new FormData(form),
      });

      if (res.ok) {
        statusEl.textContent = "Thanks for messaging us, we will get back to you shortly.";
        statusEl.style.color = "var(--lime)";
        form.reset();
      } else {
        statusEl.textContent = "Something went wrong — please email us directly.";
        statusEl.style.color = "var(--pink-light)";
      }
    } catch {
      statusEl.textContent = "Something went wrong — please email us directly.";
      statusEl.style.color = "var(--pink-light)";
    } finally {
      button.disabled = false;
    }
  });
</script>
