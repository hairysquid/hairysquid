---
import BlobField from "./BlobField.astro";
---

<section id="home" class="hero">
  <BlobField />
  <div class="hero-content">
    <img src="/logo.svg" alt="hairysquid" class="hero-logo" width="220" height="220" />
    <h1 class="hero-title">
      <span class="line">Hairysquid</span>
      <span class="line gradient-text">Ltd.</span>
    </h1>
    <p class="hero-sub">Need a website?</p>
    <a href="#approach" class="cta">I sure do! →</a>
  </div>
  <div class="scroll-hint" aria-hidden="true">
    <span></span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: radial-gradient(circle at 50% 20%, #1a1a1a, var(--ink) 65%);
  }

  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    padding: 2rem;
  }

  .hero-logo {
    filter: drop-shadow(0 0 40px rgba(236, 30, 147, 0.45));
    margin-bottom: 0.5rem;
  }

  .hero-title {
    font-size: clamp(2.8rem, 9vw, 6.5rem);
    font-weight: 900;
    line-height: 0.98;
    letter-spacing: -0.02em;
  }

  .hero-title .line {
    display: block;
    color: var(--cream);
  }

  .gradient-text {
    background: linear-gradient(90deg, var(--pink) 0%, var(--pink-light) 45%, var(--lime) 100%);
    background-size: 200% auto;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    animation: shine 5s linear infinite;
  }

  @keyframes shine {
    to { background-position: 200% center; }
  }

  .hero-sub {
    font-size: clamp(1.1rem, 2.5vw, 1.6rem);
    color: rgba(255, 248, 236, 0.8);
    font-weight: 500;
    margin-top: 0.5rem;
  }

  .cta {
    margin-top: 1.5rem;
    display: inline-block;
    padding: 1rem 2.2rem;
    border-radius: 999px;
    font-weight: 800;
    font-size: 1.1rem;
    text-decoration: none;
    color: var(--ink);
    background: linear-gradient(90deg, var(--lime), var(--pink-light));
    background-size: 160% auto;
    box-shadow: 0 10px 40px rgba(236, 30, 147, 0.35);
    transition: background-position 0.4s ease, transform 0.3s ease, box-shadow 0.3s ease;
  }

  .cta:hover {
    background-position: 100% center;
    transform: translateY(-3px) scale(1.03);
    box-shadow: 0 14px 50px rgba(163, 230, 0, 0.45);
  }

  .scroll-hint {
    position: absolute;
    bottom: 2.2rem;
    left: 50%;
    transform: translateX(-50%);
    width: 26px;
    height: 42px;
    border: 2px solid rgba(255, 248, 236, 0.5);
    border-radius: 14px;
    z-index: 2;
  }

  .scroll-hint span {
    position: absolute;
    top: 6px;
    left: 50%;
    width: 4px;
    height: 8px;
    margin-left: -2px;
    border-radius: 2px;
    background: var(--lime);
    animation: scrollDown 1.8s ease-in-out infinite;
  }

  @keyframes scrollDown {
    0% { opacity: 1; top: 6px; }
    70% { opacity: 0; top: 22px; }
    100% { opacity: 0; top: 6px; }
  }
</style>
